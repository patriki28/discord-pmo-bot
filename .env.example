# Discord Bot
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here

# Optional: Guild ID for faster slash command registration (commands appear immediately)
# When unset, deploy registers to all guilds; global registration can take up to an hour
# GUILD_ID=your-server-id

# Whisper.cpp paths
WHISPER_CPP_PATH=C:/path/to/whisper.cpp/build/bin/Release/whisper-cli.exe
WHISPER_MODEL_PATH=C:/path/to/whisper.cpp/models/ggml-medium.bin

# Optional: Directory for meeting transcript files (default: ./transcripts)
# TRANSCRIPTS_DIR=./transcripts

# Optional: transcription pipeline profile (accuracy|balanced|fast)
# TRANSCRIBE_PROFILE=balanced

# Optional: force language (example: en, tl, auto)
# TRANSCRIBE_LANGUAGE=en

# Optional: transcription processing controls
# TRANSCRIBE_SILENCE_MS=1000
# TRANSCRIBE_MIN_AUDIO_MS=180
# TRANSCRIBE_MAX_SEGMENT_MS=15000
# TRANSCRIBE_OVERLAP_MS=350
# TRANSCRIBE_TIMEOUT_MS=35000
# TRANSCRIBE_RETRIES=1
# TRANSCRIBE_THREADS=4
# TRANSCRIBE_QUEUE_CONCURRENCY=1
# TRANSCRIBE_NORMALIZE_AUDIO=true
# TRANSCRIBE_DOWNMIX_MONO=true
